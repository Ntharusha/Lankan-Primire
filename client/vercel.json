{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://13.201.141.85:5000/api/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "http://13.201.141.85:5000/socket.io/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
